# Copy to docker-compose.yml and change every CHANGEME_* before starting.
#   cp docker-compose.yml.example docker-compose.yml
services:
  app:
    build:
      context: ./docker
      dockerfile: Dockerfile
    container_name: hcm_app
    working_dir: /var/www
    volumes:
      - ./src:/var/www
    depends_on:
      - mysql
    networks: [hcm]

  nginx:
    image: nginx:1.27-alpine
    container_name: hcm_nginx
    ports:
      - "8080:80"        # change to "80:80" behind a reverse proxy on the server
    volumes:
      - ./src:/var/www
      - ./docker/nginx.conf:/etc/nginx/conf.d/default.conf
    depends_on:
      - app
    networks: [hcm]

  mysql:
    image: mysql:8.0
    container_name: hcm_mysql
    restart: unless-stopped
    ports:
      - "3306:3306"      # remove this line on a server; DB should not be public
    environment:
      MYSQL_DATABASE: hcm_lab
      MYSQL_ROOT_PASSWORD: CHANGEME_ROOT_PASSWORD
      MYSQL_USER: hcm
      MYSQL_PASSWORD: CHANGEME_APP_PASSWORD
    volumes:
      - mysql_data:/var/lib/mysql
    networks: [hcm]

  # local dev only - vite dev server with HMR. Skip on production.
  node:
    image: node:20-alpine
    container_name: hcm_node
    working_dir: /var/www
    volumes:
      - ./src:/var/www
    command: sh -c "npm install && npm run dev -- --host 0.0.0.0"
    ports:
      - "5173:5173"
    networks: [hcm]

volumes:
  mysql_data:

networks:
  hcm:
    driver: bridge
